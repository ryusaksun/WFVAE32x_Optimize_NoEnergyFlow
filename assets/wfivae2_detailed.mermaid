%%{init: {'theme': 'dark', 'themeVariables': {'background': '#000000', 'primaryTextColor': '#fff', 'lineColor': '#546e7a'}}}%%
flowchart TB
    %% ============ 样式 ============
    classDef io fill:#1b5e20,stroke:#4caf50,stroke-width:3px,color:#fff
    classDef conv fill:#0d47a1,stroke:#2196f3,stroke-width:2px,color:#fff
    classDef wavelet fill:#4a148c,stroke:#9c27b0,stroke-width:2px,color:#fff
    classDef energy fill:#311b92,stroke:#7c4dff,stroke-width:2px,color:#fff
    classDef attn fill:#880e4f,stroke:#e91e63,stroke-width:2px,color:#fff
    classDef latent fill:#e65100,stroke:#ff9800,stroke-width:3px,color:#000
    classDef merge fill:#004d40,stroke:#26a69a,stroke-width:2px,color:#fff
    classDef loss fill:#b71c1c,stroke:#f44336,stroke-width:2px,color:#fff

    %% ==================== INPUT ====================
    IN(["📥 INPUT<br/>Image (B, 3, H, W)"]):::io

    %% ==================== ENCODER ====================
    subgraph ENCODER["━━━━━━ ENCODER ━━━━━━"]
        direction TB

        subgraph E_STEP1["Step 1: Wavelet Decomposition"]
            E1["Haar Wavelet 2D<br/>━━━━━━━━━━<br/>RGB (3ch) → 12 coeffs<br/>LL, LH, HL, HH × 3"]:::wavelet
        end

        subgraph E_STEP2["Step 2: Initial Conv"]
            E2["Conv2d(12 → 128)"]:::conv
        end

        subgraph E_STEP3["Step 3: WFDownBlock 1"]
            E3_main["ResBlock×2 → Downsample 2×"]:::conv
            E3_energy["⚡ Energy Extract<br/>HaarWT → Conv(12→128)"]:::energy
            E3_cat(("⊕ Concat")):::merge
            E3_out["ResBlock (256→256)"]:::conv
        end

        subgraph E_STEP4["Step 4: WFDownBlock 2"]
            E4_main["ResBlock×2 → Downsample 2×"]:::conv
            E4_energy["⚡ Energy Extract<br/>HaarWT → Conv(12→128)"]:::energy
            E4_cat(("⊕ Concat")):::merge
            E4_out["ResBlock (384→512)"]:::conv
        end

        subgraph E_STEP5["Step 5: Mid Block"]
            E5["ResBlock → Self-Attention → ResBlock"]:::attn
        end

        subgraph E_STEP6["Step 6: To Latent"]
            E6["GroupNorm → SiLU → Conv(512→32)"]:::conv
        end
    end

    %% ==================== LATENT ====================
    subgraph LATENT["━━━━━━ LATENT SPACE ━━━━━━"]
        L1["Split channels: 32 → 16 + 16<br/>━━━━━━━━━━<br/>mean (μ) | log_var (σ²)"]:::latent
        L2(["Sample: z = μ + σ · ε<br/>Shape: (B, 16, H/8, W/8)"]):::latent
    end

    %% ==================== DECODER ====================
    subgraph DECODER["━━━━━━ DECODER ━━━━━━"]
        direction TB

        subgraph D_STEP1["Step 1: From Latent"]
            D1["Conv2d(16 → 512)"]:::conv
        end

        subgraph D_STEP2["Step 2: Mid Block"]
            D2["ResBlock → Self-Attention → ResBlock"]:::attn
        end

        subgraph D_STEP3["Step 3: WFUpBlock 1"]
            D3_main["ResBlock×3 → Upsample 2×"]:::conv
            D3_energy["⚡ Energy Inject<br/>Conv(128→12) → InvHaarWT"]:::energy
        end

        subgraph D_STEP4["Step 4: WFUpBlock 2"]
            D4_main["ResBlock×3 → Upsample 2×"]:::conv
            D4_energy["⚡ Energy Inject<br/>Conv(128→12) → InvHaarWT"]:::energy
            D4_add(("⊕ Add")):::merge
        end

        subgraph D_STEP5["Step 5: To Coeffs"]
            D5["GroupNorm → SiLU → Conv(128→12)"]:::conv
        end

        subgraph D_STEP6["Step 6: Wavelet Reconstruction"]
            D6["Inverse Haar Wavelet 2D<br/>━━━━━━━━━━<br/>12 coeffs → RGB (3ch)"]:::wavelet
        end
    end

    %% ==================== OUTPUT ====================
    OUT(["📤 OUTPUT<br/>Reconstructed (B, 3, H, W)"]):::io

    %% ==================== LOSS ====================
    subgraph LOSS["━━━ LOSS (Training Only) ━━━"]
        LOSS_E[["Encoder Coeffs"]]:::loss
        LOSS_D[["Decoder Coeffs"]]:::loss
        LOSS_W["Wavelet Loss<br/>MSE(enc, dec)"]:::loss
    end

    %% ==================== 主干连接 ====================
    IN ==> E1
    E1 ==> E2
    E2 ==> E3_main
    E3_main --> E3_cat
    E3_cat --> E3_out
    E3_out ==> E4_main
    E4_main --> E4_cat
    E4_cat --> E4_out
    E4_out ==> E5
    E5 ==> E6
    E6 ==> L1 --> L2

    L2 ==> D1
    D1 ==> D2
    D2 ==> D3_main
    D3_main ==> D4_main
    D4_main --> D4_add
    D4_add --> D5
    D5 --> D6
    D6 ==> OUT

    %% ==================== 能量流连接 ====================
    E1 -.->|"coeffs→"| E3_energy
    E3_energy -->|"energy"| E3_cat

    E3_energy -.->|"LL→"| E4_energy
    E4_energy -->|"energy"| E4_cat

    D3_energy -.->|"w"| D4_add
    D4_energy --> D4_add

    %% ==================== 损失连接 ====================
    E3_energy -.-> LOSS_E
    E4_energy -.-> LOSS_E
    D3_energy -.-> LOSS_D
    D4_energy -.-> LOSS_D
    LOSS_E --> LOSS_W
    LOSS_D --> LOSS_W
