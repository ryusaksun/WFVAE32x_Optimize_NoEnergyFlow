%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e1f5fe'}}}%%
flowchart LR
    subgraph Legend["图例 Legend"]
        direction TB
        leg_conv["Conv层"]
        leg_norm("Normalization")
        leg_act{"Activation"}
        leg_attn[/"Attention"/]
        leg_io(["Input/Output"])
        leg_add(("Add/Merge"))
        leg_wavelet["Wavelet Transform"]

        style leg_conv fill:#fff
        style leg_norm fill:#c8e6c9
        style leg_act fill:#fff9c4
        style leg_attn fill:#f8bbd9
        style leg_io fill:#e8f5e9
        style leg_add fill:#ffd700
        style leg_wavelet fill:#bbdefb
    end

    subgraph EnergyFlowConcept["WF-VAE 能量流机制 Energy Flow Mechanism"]
        direction TB

        subgraph Concept1["传统 VAE 问题"]
            trad_input(["Input"]) --> trad_enc["Encoder<br/>Spatial Downsampling"]
            trad_enc --> trad_bottle["Bottleneck<br/>信息丢失"]
            trad_bottle --> trad_dec["Decoder"]
            trad_dec --> trad_output(["Output<br/>高频细节模糊"])

            style trad_bottle fill:#ffcdd2
            style trad_output fill:#ffcdd2
        end

        subgraph Concept2["WF-VAE 解决方案"]
            wf_input(["Input"]) --> wf_wavelet["Haar Wavelet<br/>频率分解"]
            wf_wavelet --> wf_low["低频 LL<br/>主要结构"]
            wf_wavelet --> wf_high["高频 LH,HL,HH<br/>细节/边缘"]

            wf_low --> wf_spatial["Spatial Path<br/>Encoder/Decoder"]
            wf_high --> wf_energy["Energy Flow Path<br/>绕过瓶颈"]

            wf_spatial --> wf_merge(("合并"))
            wf_energy -.->|"Skip Connection"| wf_merge
            wf_merge --> wf_inv_wavelet["Inverse Wavelet"]
            wf_inv_wavelet --> wf_output(["Output<br/>保留高频细节"])

            style wf_high fill:#e1bee7
            style wf_energy fill:#e1bee7
            style wf_output fill:#c8e6c9
        end
    end

    subgraph HaarWavelet2D["2D Haar 小波变换 (Image)"]
        direction TB
        hw2d_in["Input (C, H, W)"]
        hw2d_filter["4个2×2滤波器<br/>stride=2"]
        hw2d_ll["LL (低-低)<br/>平均/近似"]
        hw2d_lh["LH (低-高)<br/>水平边缘"]
        hw2d_hl["HL (高-低)<br/>垂直边缘"]
        hw2d_hh["HH (高-高)<br/>对角细节"]
        hw2d_out["Output<br/>(4C, H/2, W/2)<br/>→ 12 coeffs for RGB"]

        hw2d_in --> hw2d_filter
        hw2d_filter --> hw2d_ll & hw2d_lh & hw2d_hl & hw2d_hh
        hw2d_ll & hw2d_lh & hw2d_hl & hw2d_hh --> hw2d_out

        style hw2d_ll fill:#c8e6c9
        style hw2d_lh fill:#bbdefb
        style hw2d_hl fill:#bbdefb
        style hw2d_hh fill:#e1bee7
    end

    subgraph HaarWavelet3D["3D Haar 小波变换 (Video)"]
        direction TB
        hw3d_in["Input (C, T, H, W)"]
        hw3d_filter["8个2×2×2滤波器<br/>stride=2"]
        hw3d_bands["8个频带:<br/>LLL, LLH, LHL, LHH<br/>HLL, HLH, HHL, HHH"]
        hw3d_out["Output<br/>(8C, T/2, H/2, W/2)<br/>→ 24 coeffs for RGB"]

        hw3d_in --> hw3d_filter
        hw3d_filter --> hw3d_bands
        hw3d_bands --> hw3d_out

        style hw3d_bands fill:#bbdefb
    end
