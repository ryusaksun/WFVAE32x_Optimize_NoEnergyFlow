%%{init: {'theme': 'dark', 'themeVariables': {'background': '#000000', 'primaryTextColor': '#fff'}}}%%
flowchart LR
    %% ============ 样式 ============
    classDef ioStyle fill:#2e7d32,stroke:#4caf50,stroke-width:3px,color:#fff
    classDef mainStyle fill:#1565c0,stroke:#42a5f5,stroke-width:2px,color:#fff
    classDef energyStyle fill:#4a148c,stroke:#9c27b0,stroke-width:2px,color:#fff
    classDef latentStyle fill:#e65100,stroke:#ff9800,stroke-width:3px,color:#fff
    classDef lossStyle fill:#b71c1c,stroke:#ef5350,stroke-width:2px,color:#fff

    %% ============ 简化主流程 ============
    subgraph INPUT[" "]
        I["📥 Image<br/>(B,3,H,W)"]:::ioStyle
    end

    subgraph ENC["ENCODER"]
        direction TB
        E1["HaarWT 3→12"]:::mainStyle
        E2["Conv + DownBlocks"]:::mainStyle
        E3["Mid Attention"]:::mainStyle
    end

    subgraph LAT["LATENT"]
        Z["z ~ N(μ,σ²)<br/>(B,8,H/8,W/8)"]:::latentStyle
    end

    subgraph DEC["DECODER"]
        direction TB
        D1["Mid Attention"]:::mainStyle
        D2["UpBlocks + Conv"]:::mainStyle
        D3["InvHaarWT 12→3"]:::mainStyle
    end

    subgraph OUTPUT[" "]
        O["📤 Recon<br/>(B,3,H,W)"]:::ioStyle
    end

    %% 主干流
    I ==>|"1️⃣ 编码"| E1 --> E2 --> E3 ==>|"2️⃣ 采样"| Z ==>|"3️⃣ 解码"| D1 --> D2 --> D3 ==> O

    %% ============ 能量流说明 ============
    subgraph ENERGY["⚡ Energy Flow (能量流)"]
        direction TB
        EF1["编码器内部:<br/>每层提取小波系数<br/>与空间特征 Concat"]:::energyStyle
        EF2["解码器内部:<br/>每层生成小波系数<br/>逐层累加重建"]:::energyStyle
        EF3["❌ 编码器→解码器<br/>无跳跃连接"]:::lossStyle
    end

    %% ============ 图例 ============
    subgraph LEGEND["图例"]
        L1["🔵 主干网络"]:::mainStyle
        L2["🟣 能量流"]:::energyStyle
        L3["🟠 潜在空间"]:::latentStyle
        L4["🔴 仅训练损失"]:::lossStyle
    end
