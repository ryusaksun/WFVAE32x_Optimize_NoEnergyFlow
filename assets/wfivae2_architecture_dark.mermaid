%%{init: {'theme': 'dark', 'themeVariables': {'background': '#000000', 'primaryTextColor': '#fff', 'lineColor': '#546e7a', 'fontFamily': 'monospace'}}}%%

flowchart LR
    %% ==================== Styles ====================
    classDef io fill:#1b5e20,stroke:#4caf50,stroke-width:3px,color:#fff
    classDef backbone fill:#0d47a1,stroke:#64b5f6,stroke-width:2px,color:#fff
    classDef energy fill:#4a148c,stroke:#ce93d8,stroke-width:2px,color:#fff
    classDef merge fill:#e65100,stroke:#ff9800,stroke-width:2px,color:#fff
    classDef latent fill:#bf360c,stroke:#ff7043,stroke-width:3px,color:#fff
    classDef loss fill:#b71c1c,stroke:#ef9a9a,stroke-width:2px,color:#fff
    classDef attn fill:#880e4f,stroke:#f48fb1,stroke-width:2px,color:#fff

    %% ==================== LEFT: BACKBONE ====================
    subgraph BACKBONE["BACKBONE"]
        direction TB

        IN(["INPUT\n(B,3,H,W)"]):::io

        subgraph ENC["ENCODER"]
            direction TB
            E1["HaarWaveletTransform2D\n-----------------------\nInput: (B, 3, H, W)\nOp: 2D wavelet decompose\nOutput: (B, 12, H/2, W/2)\n-----------------------\n12 = LL,LH,HL,HH x 3ch"]:::backbone

            E2["Conv2d(12, 128, k=3, p=1)\n-----------------------\nInput: (B, 12, H/2, W/2)\nOp: channel expansion\nOutput: (B, 128, H/2, W/2)"]:::backbone

            E3["WFDownBlock-1\n-----------------------\nResnetBlock2D x 2\nDownsample (stride=2)\n-----------------------\nInput: (B, 128, H/2, W/2)\nOutput: (B, 128, H/4, W/4)"]:::backbone

            E3_M(("CONCAT\n128+128\n=256")):::merge

            E4["ResnetBlock2D(256, 256)\n-----------------------\nInput: (B, 256, H/4, W/4)\nOp: feature fusion\nOutput: (B, 256, H/4, W/4)"]:::backbone

            E5["WFDownBlock-2\n-----------------------\nResnetBlock2D x 2\nDownsample (stride=2)\n-----------------------\nInput: (B, 256, H/4, W/4)\nOutput: (B, 256, H/8, W/8)"]:::backbone

            E5_M(("CONCAT\n256+128\n=384")):::merge

            E6["ResnetBlock2D(384, 512)\n-----------------------\nInput: (B, 384, H/8, W/8)\nOp: feature fusion\nOutput: (B, 512, H/8, W/8)"]:::backbone

            E7["Mid Block\n-----------------------\nResnetBlock2D\nAttention2DFix (self-attn)\nResnetBlock2D\n-----------------------\nShape: (B, 512, H/8, W/8)"]:::attn

            E8["Conv2d(512, 32, k=3, p=1)\n-----------------------\nInput: (B, 512, H/8, W/8)\nOp: to latent params\nOutput: (B, 32, H/8, W/8)\n-----------------------\n32 = 16(mu) + 16(logvar)"]:::backbone
        end

        subgraph LAT["LATENT SPACE"]
            direction TB
            L1["DiagonalGaussianDistribution\n-----------------------\nSplit: 32 -> 16 + 16\nmu: (B, 16, H/8, W/8)\nlogvar: (B, 16, H/8, W/8)"]:::latent

            L2["Reparameterization\n-----------------------\nz = mu + sigma * epsilon\nepsilon ~ N(0, 1)\n-----------------------\nOutput: z (B, 16, H/8, W/8)"]:::latent
        end

        subgraph DEC["DECODER"]
            direction TB
            D1["Conv2d(16, 512, k=3, p=1)\n-----------------------\nInput: z (B, 16, H/8, W/8)\nOp: channel expansion\nOutput: (B, 512, H/8, W/8)"]:::backbone

            D2["Mid Block\n-----------------------\nResnetBlock2D\nAttention2DFix (self-attn)\nResnetBlock2D\n-----------------------\nShape: (B, 512, H/8, W/8)"]:::attn

            D3["WFUpBlock-1\n-----------------------\nBranchConv: 512 -> 640\nSplit: [:,:512] + [:,-128:]\nResnetBlock2D x 2\nUpsample 2x\nResnetBlock2D(512, 256)\n-----------------------\nOutput: (B, 256, H/4, W/4)"]:::backbone

            D4["WFUpBlock-2\n-----------------------\nBranchConv: 256 -> 384\nSplit: [:,:256] + [:,-128:]\nResnetBlock2D x 2\nUpsample 2x\nResnetBlock2D(256, 128)\n-----------------------\nOutput: (B, 128, H/2, W/2)"]:::backbone

            D4_M(("ADD\nLL += w2")):::merge

            D5["Conv2d(128, 12, k=3, p=1)\n-----------------------\nInput: (B, 128, H/2, W/2)\nOp: to wavelet coeffs\nOutput: (B, 12, H/2, W/2)"]:::backbone

            D6["InverseHaarWaveletTransform2D\n-----------------------\nInput: (B, 12, H/2, W/2)\nOp: wavelet reconstruct\nOutput: (B, 3, H, W)"]:::backbone
        end

        OUT(["OUTPUT\n(B,3,H,W)"]):::io

        %% Backbone connections
        IN --> E1 --> E2 --> E3 --> E3_M --> E4 --> E5 --> E5_M --> E6 --> E7 --> E8
        E8 --> L1 --> L2
        L2 --> D1 --> D2 --> D3 --> D4 --> D4_M --> D5 --> D6 --> OUT
    end

    %% ==================== RIGHT: ENERGY FLOW ====================
    subgraph ENERGY["ENERGY FLOW"]
        direction TB

        subgraph ENC_EF["Encoder Energy Extract"]
            direction TB
            EF1["Level-1 Energy Extract\n-----------------------\nInput: coeffs from E1\n       coeffs[:,:3] (LL only)\n-----------------------\nHaarWaveletTransform2D:\n  (B,3,H/2,W/2) -> (B,12,H/4,W/4)\nConv2d(12, 128):\n  (B,12,H/4,W/4) -> (B,128,H/4,W/4)\n-----------------------\nOutput: energy features 128ch"]:::energy

            EF2["Level-2 Energy Extract\n-----------------------\nInput: LL from EF1 coeffs\n       coeffs[:,:3]\n-----------------------\nHaarWaveletTransform2D:\n  (B,3,H/4,W/4) -> (B,12,H/8,W/8)\nConv2d(12, 128):\n  (B,12,H/8,W/8) -> (B,128,H/8,W/8)\n-----------------------\nOutput: energy features 128ch"]:::energy
        end

        NOTE["NO CROSS-MODULE TRANSFER\n-----------------------\nEncoder coeffs are NOT\npassed to Decoder.\nOnly used for Loss calc."]:::loss

        subgraph DEC_EF["Decoder Energy Generate"]
            direction TB
            DF1["Level-1 Energy Generate\n-----------------------\nInput: D3 branch [:,-128:]\n       (B, 128, H/8, W/8)\n-----------------------\nResnetBlock2D(128, 128)\nConv2d(128, 12):\n  -> coeffs (B,12,H/8,W/8)\nInverseHaarWaveletTransform2D:\n  -> w1 (B,3,H/4,W/4)\n-----------------------\nOutput: w1 for next level"]:::energy

            DF2["Level-2 Energy Generate\n-----------------------\nInput: D4 branch [:,-128:]\n       (B, 128, H/4, W/4)\n-----------------------\nResnetBlock2D(128, 128)\nConv2d(128, 12):\n  -> coeffs (B,12,H/4,W/4)\nADD: coeffs[:,:3] += w1\nInverseHaarWaveletTransform2D:\n  -> w2 (B,3,H/2,W/2)\n-----------------------\nOutput: w2 for final output"]:::energy
        end

        %% Energy flow internal connections (removed duplicates)
        EF2 --> NOTE
    end

    %% ==================== BOTTOM: LOSS ====================
    subgraph LOSS_CALC["TRAINING LOSS"]
        direction LR
        LOSS_E[["enc_coeffs\nfrom EF1, EF2"]]:::loss
        LOSS_D[["dec_coeffs\nfrom DF1, DF2"]]:::loss
        LOSS_W["Wavelet Loss\nMSE(enc, dec)"]:::loss
        LOSS_E --> LOSS_W
        LOSS_D --> LOSS_W
    end

    %% ==================== Cross-module connections ====================
    %% Encoder: backbone -> energy
    E1 -.->|"coeffs[:,:3]"| EF1

    %% Energy: EF1 -> EF2 (LL coeffs pass)
    EF1 -.->|"LL coeffs[:,:3]"| EF2

    %% Energy -> backbone (merge)
    EF1 -.->|"energy 128ch"| E3_M
    EF2 -.->|"energy 128ch"| E5_M

    %% Decoder: backbone -> energy
    D3 -.->|"branch [:,-128:]"| DF1
    D4 -.->|"branch [:,-128:]"| DF2

    %% Decoder energy: w1 -> w2 accumulate
    DF1 -.->|"w1 accumulate"| DF2

    %% Decoder energy -> backbone (final merge)
    DF2 -.->|"w2 to output"| D4_M

    %% Loss connections
    EF1 -.-> LOSS_E
    EF2 -.-> LOSS_E
    DF1 -.-> LOSS_D
    DF2 -.-> LOSS_D
